{
  "name": "vibevellium",
  "private": true,
  "version": "0.9.8",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "predev:server": "node scripts/ensure-better-sqlite3.cjs && node scripts/ensure-dev-port.cjs",
    "dev:electron": "npm run build:electron-main && npm run build:electron-preload && concurrently -n server,vite,electron -c blue,green,magenta \"npm run dev:server\" \"npm run dev:frontend\" \"wait-on -t 120000 http-get://localhost:1420 http-get://127.0.0.1:3002/api/health && electron .\"",
    "rebuild:native": "npm rebuild better-sqlite3",
    "rebuild:native:electron": "npx electron-rebuild -f -w better-sqlite3 -v 41.2.0",
    "build": "tsc -b && vite build",
    "build:icons": "node scripts/run-build-icons.cjs",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=server-bundle.mjs --external:better-sqlite3 --packages=external",
    "build:electron-main": "esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=dist-electron/main.cjs --external:electron",
    "build:electron-preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "build:desktop": "npm run build && npm run build:icons && npm run build:server && npm run build:electron-main && npm run build:electron-preload",
    "headless": "npm run build && npm run build:server && node server-bundle.mjs --headless",
    "dist": "node scripts/run-dist.cjs",
    "dist:mac": "node scripts/run-dist.cjs --mac",
    "dist:linux": "node scripts/run-dist.cjs --linux AppImage",
    "dist:win": "node scripts/run-dist.cjs --win",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "docx": "^9.5.3",
    "express": "^4.21.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "pdf-parse": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "axios": "1.16.0",
    "follow-redirects": "1.16.0",
    "ip-address": "10.2.0",
    "lodash": "4.18.1",
    "path-to-regexp": "0.1.13",
    "tar": "7.5.13",
    "rollup": "4.59.0",
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "fdir": {
      "picomatch": "4.0.4"
    }
  },
  "build": {
    "appId": "com.vibevellium.app",
    "productName": "VibeVellium",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "server-bundle.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/bundled-plugins",
        "to": "data/bundled-plugins",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "buildDependenciesFromSource": true,
    "npmRebuild": true,
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
